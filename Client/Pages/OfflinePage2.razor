@page "/offline2"
@rendermode Microsoft.AspNetCore.Components.Web.RenderMode.InteractiveWebAssembly
@implements IDisposable
@inject TestBlazor.Client.Services.CounterService CounterService

<h3>Offline Page 2</h3>

<p>This is another page that works offline.</p>

<div class="alert alert-success">
    <strong>Success!</strong> You navigated here successfully.
</div>

<NavLink href="offline1" class="btn btn-primary" data-enhance-nav="false">Go to Offline Page 1</NavLink>

<!-- Shared Counter UI -->
<div class="card mt-4 shadow-sm" style="max-width: 400px;">
    <div class="card-header bg-success text-white">
        <h5 class="mb-0">Compteur Partagé</h5>
    </div>
    <div class="card-body text-center">
        <p class="fs-4">Valeur du compteur : <strong>@CounterService.Count</strong></p>
        <button class="btn btn-primary" @onclick="CounterService.IncrementCountAsync">
            Incrémenter le compteur
        </button>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        CounterService.OnCountChanged += StateHasChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await CounterService.InitializeAsync();
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        CounterService.OnCountChanged -= StateHasChanged;
    }
}
